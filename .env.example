# Supabase / PostgreSQL Connection String
# Thay <password> bằng mật khẩu DB của bạn trên Supabase Dashboard.
# Đối với Prisma, nên dùng chế độ pooling (Port 6543) nếu chạy trên Serverless (Vercel).
DATABASE_URL="postgresql://postgres:<password>@db.xxx.supabase.co:6543/postgres?pgbouncer=true"

# Direct connection (Dùng khi chạy migrations cục bộ - Port 5432)
DIRECT_URL="postgresql://postgres:<password>@db.xxx.supabase.co:5432/postgres"
